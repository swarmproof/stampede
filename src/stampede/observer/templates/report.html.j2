<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Agent Readiness Report — {{ r.run_id }}</title>
<style>
  :root {
    --oxblood: #6b1f2a; --oxblood-2: #8f2d3b; --ink: #1b1712; --paper: #faf6f0;
    --muted: #7a6f63; --line: #e6ddd1; --ok: #2f7d4f; --warn: #b8860b; --bad: #b03030;
  }
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--paper); color: var(--ink);
    font: 15px/1.5 "Iowan Old Style", "Palatino Linotype", Georgia, serif; }
  .wrap { max-width: 960px; margin: 0 auto; padding: 40px 24px 80px; }
  header { border-bottom: 3px solid var(--oxblood); padding-bottom: 18px; margin-bottom: 8px; }
  h1 { font-size: 30px; margin: 0 0 4px; letter-spacing: -0.01em; }
  h1 small { color: var(--oxblood); font-weight: 600; }
  h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--oxblood); margin: 40px 0 12px; border-bottom: 1px solid var(--line); padding-bottom: 6px; }
  .sub { color: var(--muted); font-size: 13px; }
  .grade { display: inline-flex; align-items: center; justify-content: center;
    width: 64px; height: 64px; border-radius: 12px; background: var(--oxblood); color: #fff;
    font-size: 34px; font-weight: 700; float: right; font-family: system-ui, sans-serif; }
  .kpis { display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0 4px; }
  .kpi { flex: 1; min-width: 120px; }
  .kpi .v { font-size: 26px; font-weight: 700; font-family: system-ui, sans-serif; }
  .kpi .l { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  table { width: 100%; border-collapse: collapse; margin: 6px 0; font-size: 14px; }
  th { text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--muted); border-bottom: 1px solid var(--line); padding: 8px 10px; }
  td { padding: 8px 10px; border-bottom: 1px solid var(--line); font-variant-numeric: tabular-nums; }
  .mono { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 13px; }
  .bar { height: 7px; border-radius: 4px; background: var(--oxblood); display: inline-block; vertical-align: middle; }
  .track { background: var(--line); border-radius: 4px; width: 120px; display: inline-block; vertical-align: middle; }
  .pill { font-family: system-ui, sans-serif; font-size: 11px; padding: 2px 8px; border-radius: 999px; }
  .pill.ok { background: #e3f0e8; color: var(--ok); }
  .pill.bad { background: #f6e3e3; color: var(--bad); }
  .lead { font-size: 16px; }
  .lead b { color: var(--oxblood); }
  footer { margin-top: 60px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--line); padding-top: 16px; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="grade" title="overall grade">{{ r.grade }}</div>
    <h1>Agent Readiness Report <small>· stampede</small></h1>
    <div class="sub">{{ m.target }} · {{ m.size }} agents · seed {{ m.seed }} · run <span class="mono">{{ r.run_id }}</span></div>
  </header>

  <div class="kpis">
    <div class="kpi"><div class="v">{{ (overall_success * 100) | round(0) | int }}%</div><div class="l">task success</div></div>
    <div class="kpi"><div class="v">{{ (overall_misuse * 100) | round(0) | int }}%</div><div class="l">misuse (labeled)</div></div>
    <div class="kpi"><div class="v">{{ r.cost_spread }}×</div><div class="l">cost spread</div></div>
    <div class="kpi"><div class="v">${{ m.total_usd }}</div><div class="l">modeled spend</div></div>
    <div class="kpi"><div class="v">{{ r.chaos.exactly_once_violations }}</div><div class="l">exactly-once violations</div></div>
  </div>

  {% if r.misuse_map %}
  <h2>Misuse map</h2>
  <p class="lead">Where agents called the <b>wrong tool</b> for their goal — your descriptions may be ambiguous.</p>
  <table>
    <thead><tr><th>Goal expected</th><th>Agents called</th><th>Confusion</th><th>n (labeled)</th></tr></thead>
    <tbody>
    {% for x in r.misuse_map %}
      <tr>
        <td class="mono">{{ x.expected_tool }}</td>
        <td class="mono">{{ x.realized_tool }}</td>
        <td>
          <span class="track"><span class="bar" style="width: {{ (x.confusion_rate * 120) | round(0) | int }}px"></span></span>
          {{ (x.confusion_rate * 100) | round(0) | int }}%
        </td>
        <td>{{ x.n_labeled }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <h2>Task success by persona</h2>
  <table>
    <thead><tr><th>Persona</th><th>Agents</th><th>Success</th><th>Misuse</th></tr></thead>
    <tbody>
    {% for s in r.success %}
      <tr>
        <td>{{ s.persona }}</td>
        <td>{{ s.n }}</td>
        <td>{{ (s.success_rate * 100) | round(0) | int }}%</td>
        <td>{{ (s.misuse_rate * 100) | round(0) | int }}%</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Cost profile</h2>
  <table>
    <thead><tr><th>Persona</th><th>Mean $</th><th>p95 $</th><th>Mean tokens</th></tr></thead>
    <tbody>
    {% for c in r.cost_profile %}
      <tr>
        <td>{{ c.persona }}</td>
        <td>${{ '%.4f' | format(c.usd_mean) }}</td>
        <td>${{ '%.4f' | format(c.usd_p95) }}</td>
        <td>{{ c.tokens_mean | round(0) | int }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Concurrency &amp; performance</h2>
  <div class="kpis">
    <div class="kpi"><div class="v">{{ r.performance.p50_ticks }}</div><div class="l">p50 ms</div></div>
    <div class="kpi"><div class="v">{{ r.performance.p95_ticks }}</div><div class="l">p95 ms</div></div>
    <div class="kpi"><div class="v">{{ r.performance.p99_ticks }}</div><div class="l">p99 ms</div></div>
    <div class="kpi"><div class="v">{{ r.performance.dropped_connections }}</div><div class="l">dropped</div></div>
    <div class="kpi"><div class="v">{{ r.performance.max_stable_concurrency }}</div><div class="l">peak concurrency</div></div>
  </div>

  <h2>Chaos &amp; recovery</h2>
  {% if r.chaos.faults_injected %}
  <table>
    <thead><tr><th>Fault</th><th>Count</th></tr></thead>
    <tbody>
    {% for k, v in r.chaos.faults_injected.items() %}
      <tr><td class="mono">{{ k }}</td><td>{{ v }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  <p>
    Recovery findings: {{ r.chaos.recovery_findings | length }} ·
    {% if r.chaos.exactly_once_violations == 0 %}
      <span class="pill ok">exactly-once holds</span>
    {% else %}
      <span class="pill bad">{{ r.chaos.exactly_once_violations }} exactly-once violation(s)</span>
    {% endif %}
  </p>
  {% else %}
  <p class="sub">No chaos configured for this run.</p>
  {% endif %}

  <h2>Adversarial cohort</h2>
  <div class="kpis">
    <div class="kpi"><div class="v">{{ r.adversarial.cohort_size }}</div><div class="l">adversarial agents</div></div>
    <div class="kpi"><div class="v">{{ r.adversarial.destructive_reached }}</div><div class="l">reached destructive tool</div></div>
    <div class="kpi"><div class="v">{{ r.adversarial.denial_of_wallet_flags }}</div><div class="l">denial-of-wallet flags</div></div>
  </div>

  <footer>
    Generated by <b>stampede</b> — the wind tunnel for the agent economy · safety posture:
    <span class="mono">{{ m.safety_posture }}</span> · Apache-2.0
  </footer>
</div>
</body>
</html>
